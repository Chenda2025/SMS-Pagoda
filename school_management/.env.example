SECRET_KEY=replace-with-a-strong-random-value
DEBUG=False

# Production (Render): set this to Neon's connection string instead of the
# DB_* vars below, e.g. postgresql://user:pass@ep-xxx.neon.tech/dbname
DATABASE_URL=

# Local dev only -- ignored if DATABASE_URL is set.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# Comma-separated list of hostnames this app is allowed to serve, e.g.
# your-app.onrender.com. Leave unset only for local development.
ALLOWED_HOSTS=

# Comma-separated list of origins allowed to call this API cross-origin,
# e.g. https://your-frontend.onrender.com
CORS_ALLOWED_ORIGINS=
